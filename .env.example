# =====================================================================
# Terramind .env.example
# Copie para .env e ajuste os valores. NUNCA versione o .env real.
# =====================================================================

# --- Postgres ---
POSTGRES_USER=terramind
POSTGRES_PASSWORD=terramind_dev_password
POSTGRES_DB=terramind
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- RabbitMQ ---
RABBITMQ_USER=terramind
RABBITMQ_PASSWORD=terramind_dev_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Secrets (mínimo 32 caracteres em produção) ---
JWT_SECRET=please-change-me-to-a-32-char-minimum-secret-12345
EVENT_SIGNING_SECRET=another-32-char-minimum-secret-for-hmac-12345

# --- JWT ---
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# --- CORS (separar por vírgula) ---
CORS_ALLOWED_ORIGINS=https://localhost:8443,http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Database URLs por serviço (geradas automaticamente no compose) ---
# DATABASE_URL=postgresql+asyncpg://terramind:terramind_dev_password@postgres:5432/terramind
# AMQP_URL=amqp://terramind:terramind_dev_password@rabbitmq:5672/
